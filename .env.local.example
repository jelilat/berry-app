# Compiler backend: local (PlatformIO), mock, or remote
BERRY_BUILD_BACKEND=local

# Auth mode: disabled for local/open-source installs, optional to allow sign-in,
# required for hosted app. Supabase vars are only needed for optional/required.
NEXT_PUBLIC_AUTH_MODE=disabled
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional monthly agent token cap per user. Leave unset for no limit.
# AGENT_MONTHLY_TOKEN_LIMIT=50000

# Optional: full path to pio when pip --user install is not on PATH
# BERRY_PLATFORMIO_BIN=$HOME/Library/Python/3.9/bin/pio

# Use mock for UI dev without PlatformIO installed:
# BERRY_BUILD_BACKEND=mock

# AI provider: unset for local deterministic fallback, or openai/anthropic for real hosted AI.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# BERRY_AI_PROVIDER=openai
# BERRY_AI_REQUIRE_REAL=true

# OpenAI model overrides:
# BERRY_AI_FAST_MODEL=gpt-5.4-mini
# BERRY_AI_STRONG_MODEL=gpt-5.5
# BERRY_AI_CODE_MODEL=gpt-5.5
# BERRY_AI_WRITER_MODEL=gpt-5.4-mini

# Anthropic model overrides:
# BERRY_AI_FAST_MODEL=claude-sonnet-4-6
# BERRY_AI_STRONG_MODEL=claude-fable-5
# BERRY_AI_CODE_MODEL=claude-opus-4-8
# BERRY_AI_WRITER_MODEL=claude-sonnet-4-6
