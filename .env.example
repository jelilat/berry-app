# Runtime
# Cloudflare/OpenNext builds should use Node 20+ because Supabase JS requires it.
NODE_VERSION=20

# Compiler backend: local (PlatformIO), mock, or remote.
# Use mock for local UI development without PlatformIO installed.
BERRY_BUILD_BACKEND=local

# Optional: full path to pio when pip --user install is not on PATH.
# BERRY_PLATFORMIO_BIN=$HOME/Library/Python/3.9/bin/pio

# Auth mode:
# - disabled: open-source/local default, no Supabase required, projects save locally.
# - optional: sign-in and cloud sync are available when Supabase vars are set.
# - required: hosted app mode, sign-in is required for custom builds.
NEXT_PUBLIC_AUTH_MODE=disabled

# Supabase auth + cloud project storage.
# Required only when NEXT_PUBLIC_AUTH_MODE is optional or required.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# AI provider:
# Leave unset for deterministic local fallback.
# Set BERRY_AI_PROVIDER=openai and OPENAI_API_KEY for real hosted AI.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# BERRY_AI_PROVIDER=openai
# BERRY_AI_REQUIRE_REAL=true

# Model overrides.
# BERRY_AI_FAST_MODEL=gpt-5-mini
# BERRY_AI_STRONG_MODEL=gpt-5
# BERRY_AI_CODE_MODEL=gpt-5
# BERRY_AI_WRITER_MODEL=gpt-5-mini
